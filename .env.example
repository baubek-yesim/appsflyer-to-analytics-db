# Copy to .env and fill in real values. .env is gitignored — never commit it.
# On the server, these same keys are provided via a systemd EnvironmentFile instead
# (see deploy/appsflyer-daily.service + docs/RUNBOOK.md).

# --- Analytics database (MariaDB/MySQL) ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=analytics_statistics
DB_TABLE=appsflyer_events_fb

# --- AppsFlyer Pull API ---
# API token/key — get from Mark Malovichko (see BAF-2 comment).
APPSFLYER_API_TOKEN=
# Comma-separated AppsFlyer app IDs to pull, e.g. id1458505230
APPSFLYER_APP_IDS=

# --- Run parameters ---
# Media source filter applied to both API pulls.
APPSFLYER_MEDIA_SOURCE=Facebook Ads
# Comma-separated event names to keep.
APPSFLYER_EVENT_NAMES=af_purchase,af_purchase_YC
