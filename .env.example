# Copy to .env and fill in real values. .env is gitignored — never commit it.
# On the server, these same keys are provided via a systemd EnvironmentFile instead
# (see deploy/appsflyer-daily.service + docs/RUNBOOK.md).

# --- Analytics database (MariaDB/MySQL) ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=analytics_statistics
DB_TABLE=appsflyer_events_fb

# --- AppsFlyer Pull API ---
# API token/key — get from Mark Malovichko (see BAF-2 comment).
APPSFLYER_API_TOKEN=
# Comma-separated AppsFlyer app IDs to pull. OPTIONAL (issue #48): defaults to
# the production roster com.yesimmobile,id1458505230 when unset. Leaving the
# line present-but-empty is an error (issue #9) — set it or keep it commented.
#APPSFLYER_APP_IDS=com.yesimmobile,id1458505230

# --- Run parameters ---
# Media source filter applied to both API pulls.
APPSFLYER_MEDIA_SOURCE=Facebook Ads
# Comma-separated event names to keep.
APPSFLYER_EVENT_NAMES=af_purchase,af_purchase_YC
# Optional event-time window for the flagless `daily` run (issue #50): maps
# straight onto the API's from/to (which filter on event time). FROM required
# for TO; TO defaults to yesterday. CAUTION: a standing FROM older than the
# API's ~35-day availability floor meets valid-looking EMPTY responses and the
# idempotent delete-then-insert would wipe already-loaded rows (issue #45).
#APPSFLYER_EVENT_TIME_FROM=2026-06-04
#APPSFLYER_EVENT_TIME_TO=2026-07-08
