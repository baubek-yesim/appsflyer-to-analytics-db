# Template for the server-side systemd EnvironmentFile.
#
# Copy to /etc/appsflyer/appsflyer.env, fill in real values, then:
#   chmod 600 /etc/appsflyer/appsflyer.env
#   chown appsflyer:appsflyer /etc/appsflyer/appsflyer.env
# NEVER commit the filled-in file (the real `appsflyer.env` filename, unlike
# this `.example`, already matches this repo's `.gitignore` `*.env` rule).
#
# This is a systemd EnvironmentFile, NOT a shell script:
#   - no `export`, no $VAR expansion, no command substitution
#   - a value with spaces is written literally, unquoted (see APPSFLYER_MEDIA_SOURCE)
#   - lists are plain comma-separated -- NOT a JSON array (config.py's CsvList
#     type disables JSON auto-decoding, so a "[...]" value would be split on
#     commas into garbage tokens instead of parsed as JSON)
#   - only wrap a value in "double quotes" if it has leading/trailing spaces
#     or starts with # or " -- see docs/RUNBOOK.md

# --- Analytics database (MariaDB/MySQL) ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=analytics_statistics
DB_TABLE=appsflyer_events_fb

# --- AppsFlyer Pull API ---
# API token -- get from Mark Malovichko (see BAF-2 comment).
APPSFLYER_API_TOKEN=
# Comma-separated AppsFlyer app IDs, no spaces, no brackets: id1,id2
# OPTIONAL (issue #48): defaults to com.yesimmobile,id1458505230 when unset.
# A present-but-empty line is a startup error (issue #9) — set it or comment it out.
#APPSFLYER_APP_IDS=com.yesimmobile,id1458505230

# --- Run parameters ---
# Literal space, unquoted -- do not wrap in quotes.
APPSFLYER_MEDIA_SOURCE=Facebook Ads
# Comma-separated, not a JSON array.
APPSFLYER_EVENT_NAMES=af_purchase,af_purchase_YC
# Daily trailing-window depth (issue #8): the scheduled `daily` run pulls
# [yesterday-(N-1), yesterday]. Default (unset) = 1, the original single-day
# pull. Recommended in production: 3 -- the timer fires at 05:00 +03, which is
# exactly AppsFlyer's 02:00 UTC late-event boundary, and offline devices'
# SDK-cached events can arrive days late; a 3-day window re-captures them at
# ZERO extra API quota (any depth <=31 days is still one report download per
# app/attribution per run). Loads are idempotent, so the daily rewrite is safe.
#APPSFLYER_DAILY_LOOKBACK_DAYS=3
# Optional event-time window (issue #50) -- when FROM is set, the flagless
# `daily` run pulls exactly [FROM, TO or yesterday] instead of the lookback;
# an explicit --date still wins. Maps straight onto the API's from/to (event
# time). CAUTION: a standing FROM older than the API's ~35-day availability
# floor meets valid-looking EMPTY responses, and the idempotent
# delete-then-insert would wipe already-loaded rows (issue #45) -- the run
# warns but proceeds. Keep FROM well inside the floor, or leave both unset.
#APPSFLYER_EVENT_TIME_FROM=2026-06-04
#APPSFLYER_EVENT_TIME_TO=2026-07-08
